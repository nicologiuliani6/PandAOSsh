term0.uriscv
term*.uriscv.out

# --- Artefatti di build del kernel ---
MultiPandOS
MultiPandOS.core.uriscv
MultiPandOS.stab.uriscv

# --- Artefatti di build delle U-proc di test (rigenerabili con make in testers/) ---
testers/*.elf
testers/*.aout.uriscv
testers/*.uriscv

# --- Archivi ---
*.tar.gz
*.zip

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
*.swp
