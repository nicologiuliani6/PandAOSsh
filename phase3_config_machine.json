{
    "boot": {
        "core-file": "build/MultiPandOS.core.uriscv",
        "load-core-file": true
    },
    "bootstrap-rom": "/usr/local/share/uriscv/coreboot.rom.uriscv",
    "clock-rate": 1,
    "devices": {
        "flash0": {
            "enabled": true,
            "file": "testers/shell.uriscv"
        },
        "flash1": {
            "enabled": true,
            "file": "testers/echo.uriscv"
        },
        "flash2": {
            "enabled": true,
            "file": "testers/fibEleven.uriscv"
        },
        "flash3": {
            "enabled": true,
            "file": "testers/uname.uriscv"
        },
        "flash4": {
            "enabled": true,
            "file": "testers/sl.uriscv"
        },
        "flash5": {
            "enabled": true,
            "file": "testers/calc.uriscv"
        },
        "flash6": {
            "enabled": false,
            "file": ""
        },
        "flash7": {
            "enabled": false,
            "file": ""
        },
        "terminal0": {
            "enabled": true,
            "file": "term0.uriscv"
        }
    },
    "execution-rom": "/usr/local/share/uriscv/exec.rom.uriscv",
    "num-processors": 1,
    "num-ram-frames": 256,
    "symbol-table": {
        "asid": 64,
        "file": "build/MultiPandOS.stab.uriscv"
    },
    "tlb-floor-address": "0x80000000",
    "tlb-size": 16
}
